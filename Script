-- Keybind System
local bindingMode = false

KeybindButton.MouseButton1Click:Connect(function()
    if bindingMode then return end
    bindingMode = true
    KeybindButton.Text = "Press a key..."
    KeybindButton.TextColor3 = Color3.fromRGB(255, 220, 80)
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    -- Binding mode: capture next key
    if bindingMode then
        if input.UserInputType == Enum.UserInputType.Keyboard then
            local name = input.KeyCode.Name
            settings.keybind = name
            KeybindButton.Text = "Bind Rejoin: " .. name
            KeybindButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            bindingMode = false
            saveSettings()
        end
        return
    end

    -- Normal keybind trigger (ignore when typing in game)
    if gpe then return end
    if input.UserInputType == Enum.UserInputType.Keyboard then
        if settings.keybind ~= "None" then
            local ok, kc = pcall(function()
                return Enum.KeyCode[settings.keybind]
            end)
            if ok and kc and input.KeyCode == kc then
                doRejoin()
            end
        end
    end
end)

-- Drag System
local dragging = false
local dragInput
local dragStart
local startPos

local function update(input)
    local delta = input.Position - dragStart
    Main.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

TitleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)
